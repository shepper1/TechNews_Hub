{
  "permissions": {
    "allow": [
      "Bash(npx next *)",
      "Bash(netstat -ano)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\" http://localhost:3000/favorites)",
      "Bash(curl -s -o /dev/null -w \" | HTTP %{http_code}\" http://localhost:3000/categories/ia)",
      "Bash(curl -s -o /dev/null -w \" | HTTP %{http_code}\" http://localhost:3000/api/articles?limit=1)",
      "Bash(curl -s \"http://localhost:3000/api/articles?limit=2\")",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('Total:', d['pagination']['total'], '| Trending count:', sum\\(1 for a in d['articles'] if a.get\\('isTrending'\\)\\)\\)\")",
      "Bash(curl -s \"http://localhost:3000/api/articles?trending=true&limit=5\")",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('Trending filter:', d['pagination']['total'], 'articles | All trending?', all\\(a.get\\('isTrending'\\) for a in d['articles']\\)\\)\")",
      "Bash(node -e \"try{const p=require\\('./node_modules/@tailwindcss/postcss/package.json'\\);console.log\\('@tailwindcss/postcss:',p.version\\)}catch\\(e\\){console.log\\('NOT installed'\\)}\")",
      "Bash(cmd.exe /c \"taskkill /PID 12600 /F\")",
      "Bash(powershell.exe -Command \"Stop-Process -Id 12600 -Force -ErrorAction SilentlyContinue; Write-Host 'done'\")"
    ]
  }
}
